                     <item>
                      <widget class="QSlider" name="picprogress">
                       <property name="focusPolicy">
                        <enum>Qt::NoFocus</enum>
                       </property>
                       <property name="statusTip">
                        <string/>
                       </property>
                       <property name="accessibleName">
                        <string/>
                       </property>
                       <property name="styleSheet">
                        <string notr="true">/* 进度条：自定义虚线图片轨道 + 实线到滑块中心（无多余白点） + PNG滑块 */
QSlider {
    background: transparent;
    height: 40px;          /* 适配滑块高度 */
    border-image:  url(:/step/image/step/空步骤.png); /* 替换为你的虚线图片实际路径 */
}

/* 1. 基础轨道：自定义虚线图片作为背景（核心修改） */
QSlider::groove:horizontal {
    height: 2px;                   /* 轨道高度（需与虚线图片高度匹配） */
    background-repeat: repeat-x;   /* 水平重复平铺图片，形成连续虚线 */
    background-position: center;   /* 图片垂直居中，避免偏移 */
    border: none;                  /* 移除原有边框虚线 */
    border-radius: 1px;
    margin: 0 12px;                /* 滑块宽度/2=24/2=12，贴合滑动范围 */
}

/* 2. 完成部分：实线到滑块中心（消除小白点核心） */
QSlider::sub-page:horizontal {
    height: 2px;                   /* 与轨道高度一致 */
    background-color: #FFFFFF;     /* 白色实线（背景填充，无边缘断点）#FFFFFF */
    border: none;                  /* 彻底去掉所有边框 */
    border-radius: 1px;
    /* 精准限定实线范围：从轨道左边界到滑块中心 */
    margin: 0 12px;                /* 修正：补充px单位，避免样式失效 */
}

/* 3. 滑块：PNG图标（覆盖实线终点，无白点） */
QSlider::handle:horizontal {
    image: url(:/step/image/step/smilingface.png); /* 你的PNG路径 */
    width: 24px;                   /* 滑块宽度 */
    height: 24px;                  /* 滑块高度 */
    background-color: transparent;
    border: none;
    /* 垂直+水平居中，滑块中心对齐实线终点 */
    margin: -11px -12px;           /* 垂直：-11px，水平：-滑块半宽 */
}
</string>
                       </property>
