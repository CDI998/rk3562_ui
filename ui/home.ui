                 <property name="styleSheet">
                  <string notr="true">/* 基础圆角按钮 */
QPushButton {
    /* 核心：圆角设置（数值越大，圆角越明显） */
    border-radius: 8px;          /* 圆角半径，建议8-16px */
    /* 基础样式（可选，保证按钮美观） */
    background-color: #8E9AAFCC;   /* 按钮背景色（蓝色，可自定义） */
    color: #ffffff;              /* 文字颜色（白色） */
    border: none;                /* 去掉默认边框 */
    padding: 6px 6px;           /* 内边距（上下6px，左右16px），避免文字贴边 */
    font-family: &quot;Microsoft YaHei&quot;;  /* 微软雅黑（英文写法，兼容所有系统） */
    font-weight: bold;              /* 加粗 */
    font-size: 25px;             /* 文字大小 */
}

QPushButton:pressed {
    background-color: rgba(255, 255, 255, 0.8); 
    padding-top: 15px;  /* 点击时修改填充 */
}
</string>
