                    <property name="styleSheet">
                     <string notr="true">QLineEdit {
    border-radius: 10px;                /* 圆润圆角 */
    border: 1px solid rgba(221, 221, 221, 0.8);  /* 边框80%不透明度，更柔和 */
    background-color: rgba(255, 255, 255, 0.9); /* 背景95%不透明度，轻微通透 */   
    color: #666666;                     /* 文字调整为浅灰色） */
}

/* 聚焦状态：轻微通透+高亮边框 */
QLineEdit:focus {
    border-color: rgba(64, 158, 255, 0.9);  /* 高亮边框90%不透明度 */
    background-color: rgba(248, 251, 255, 0.98); /* 浅蓝背景接近实色 */
    outline: none;
}

/* 禁用状态：低透明度灰色调 */
QLineEdit:disabled {
    border-radius: 10px;
    border-color: rgba(238, 238, 238, 0.9); /* 边框60%不透明度 */
    background-color: rgba(249, 249, 249, 0.7); /* 背景70%不透明度 */
    color: rgba(153, 153, 153, 0.7);    /* 文字80%不透明度 */
}</string>
